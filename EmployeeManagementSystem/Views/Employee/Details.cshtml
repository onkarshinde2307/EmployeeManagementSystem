@model EmployeeManagementSystem.Models.Employee

@{
    ViewBag.Title = "Employee Details";
}

<h2>Employee Details</h2>

<hr />

<table class="table table-bordered">

    <tr>
        <th width="200">Employee Id</th>
        <td>@Model.Id</td>
    </tr>

    <tr>
        <th>Name</th>
        <td>@Model.Name</td>
    </tr>

    <tr>
        <th>Department</th>
        <td>@Model.Department</td>
    </tr>

    <tr>
        <th>Salary</th>
        <td>@Model.Salary</td>
    </tr>

    <tr>
        <th>City</th>
        <td>@Model.City</td>
    </tr>

    <tr>
        <th>Created Date</th>
        <td>@Model.CreatedDate</td>
    </tr>

</table>

@Html.ActionLink("Back To List", "Index", null,
    new { @class = "btn btn-primary" })